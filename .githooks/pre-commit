#!/usr/bin/env bash
# Pre-commit gate: typecheck (src + tests), lint, format check, then tests.
# Skip with `git commit --no-verify` if absolutely needed.
set -e

echo "[pre-commit] typecheck"
npm run --silent typecheck

echo "[pre-commit] lint"
npm run --silent lint

echo "[pre-commit] format:check"
npm run --silent format:check

echo "[pre-commit] tests"
npm run --silent test
