{
  "version": "2.0.0",
  "tasks": [
    {
      "type": "npm",
      "script": "build",
      "label": "npm: build",
      "problemMatcher": "$tsc",
      "presentation": { "reveal": "silent" },
      "group": { "kind": "build", "isDefault": true }
    },
    {
      "type": "npm",
      "script": "watch",
      "label": "npm: watch",
      "isBackground": true,
      "problemMatcher": "$tsc-watch",
      "presentation": { "reveal": "silent" }
    },
    {
      "type": "shell",
      "command": "node",
      "args": ["scripts/make-screenshot-fixture.js"],
      "label": "screenshot: fixture",
      "presentation": { "reveal": "always", "panel": "shared", "clear": true },
      "problemMatcher": []
    },
    {
      "label": "screenshot: prep",
      "dependsOrder": "sequence",
      "dependsOn": ["npm: build", "screenshot: fixture"],
      "problemMatcher": []
    }
  ]
}
