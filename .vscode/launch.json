{
  "version": "0.2.0",
  "configurations": [
    {
      "name": "Run Extension",
      "type": "extensionHost",
      "request": "launch",
      "args": ["--extensionDevelopmentPath=${workspaceFolder}"],
      "outFiles": ["${workspaceFolder}/out/**/*.js"],
      "preLaunchTask": "npm: build"
    },
    {
      "name": "Extension: Screenshot Demo",
      "type": "extensionHost",
      "request": "launch",
      "args": [
        "--extensionDevelopmentPath=${workspaceFolder}",
        "/tmp/coding-session-todos-screenshot/work/web-dashboard"
      ],
      "env": { "HOME": "/tmp/coding-session-todos-screenshot" },
      "outFiles": ["${workspaceFolder}/out/**/*.js"],
      "preLaunchTask": "screenshot: prep"
    }
  ]
}
