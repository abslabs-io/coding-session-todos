{
  "name": "claude-todos",
  "displayName": "Claude Todos",
  "description": "Live sidebar view of Claude Code session todos for the current workspace.",
  "version": "0.0.15",
  "publisher": "local",
  "license": "MIT",
  "author": "Abhishek Kapadiya",
  "icon": "media/icon-128.png",
  "engines": {
    "vscode": "^1.85.0"
  },
  "categories": [
    "AI",
    "Visualization",
    "Other"
  ],
  "keywords": [
    "claude",
    "claude code",
    "todos",
    "tasks",
    "ai",
    "agent"
  ],
  "repository": {
    "type": "git",
    "url": "https://github.com/abslabs-io/claude-todos.git"
  },
  "bugs": {
    "url": "https://github.com/abslabs-io/claude-todos/issues"
  },
  "homepage": "https://github.com/abslabs-io/claude-todos#readme",
  "main": "./out/extension.js",
  "activationEvents": [
    "onStartupFinished"
  ],
  "contributes": {
    "viewsContainers": {
      "activitybar": [
        {
          "id": "claudeTodos",
          "title": "Claude Todos",
          "icon": "media/icon.svg"
        }
      ]
    },
    "views": {
      "claudeTodos": [
        {
          "id": "claudeTodos.list",
          "name": "Todos",
          "type": "tree"
        }
      ]
    },
    "viewsWelcome": [
      {
        "view": "claudeTodos.list",
        "contents": "No active Claude sessions found.\n\nSessions appear here once Claude Code touches a transcript in this workspace, or within the active session window (configurable via `claudeTodos.activeSessionMinutes`, default 30 minutes).\n\n[Refresh](command:claudeTodos.refresh)\n[Open Settings](command:claudeTodos.openSettings)",
        "when": "claudeTodos.state == noSessions"
      }
    ],
    "commands": [
      {
        "command": "claudeTodos.refresh",
        "title": "Refresh Claude Todos",
        "icon": "$(refresh)"
      },
      {
        "command": "claudeTodos.expandAll",
        "title": "Expand All Claude Todos",
        "icon": "$(expand-all)"
      },
      {
        "command": "claudeTodos.collapseAll",
        "title": "Collapse All Claude Todos",
        "icon": "$(collapse-all)"
      },
      {
        "command": "claudeTodos.openSettings",
        "title": "Claude Todos Settings",
        "icon": "$(gear)"
      }
    ],
    "menus": {
      "view/title": [
        {
          "command": "claudeTodos.refresh",
          "when": "view == claudeTodos.list",
          "group": "navigation@1"
        },
        {
          "command": "claudeTodos.expandAll",
          "when": "view == claudeTodos.list",
          "group": "navigation@2"
        },
        {
          "command": "claudeTodos.collapseAll",
          "when": "view == claudeTodos.list",
          "group": "navigation@3"
        },
        {
          "command": "claudeTodos.openSettings",
          "when": "view == claudeTodos.list",
          "group": "navigation@4"
        }
      ]
    },
    "configuration": {
      "title": "Claude Todos",
      "properties": {
        "claudeTodos.activeSessionMinutes": {
          "type": "number",
          "default": 30,
          "minimum": 5,
          "maximum": 1440,
          "description": "How recently a Claude session must have been touched (in minutes) to appear in the panel. Default 30, max 1 day."
        }
      }
    }
  },
  "scripts": {
    "build": "tsc -p .",
    "watch": "tsc -p . -w",
    "icon": "node scripts/gen-icon.js",
    "package": "vsce package",
    "vscode:prepublish": "tsc -p .",
    "typecheck": "tsc --noEmit -p tsconfig.test.json",
    "lint": "eslint .",
    "format": "prettier --write .",
    "format:check": "prettier --check .",
    "test": "vitest run",
    "test:watch": "vitest",
    "prepare": "node scripts/setup-hooks.js"
  },
  "devDependencies": {
    "@eslint/js": "^10.0.1",
    "@types/node": "^24.0.0",
    "@types/vscode": "^1.85.0",
    "@vscode/vsce": "^3.9.1",
    "eslint": "^10.5.0",
    "eslint-config-prettier": "^10.1.8",
    "prettier": "^3.8.4",
    "typescript": "^5.4.0",
    "typescript-eslint": "^8.62.0",
    "vitest": "^4.1.7"
  }
}
