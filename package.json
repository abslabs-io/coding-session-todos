{
  "name": "claude-todos",
  "displayName": "Claude Todos",
  "description": "Live sidebar view of Claude Code session todos for the current workspace.",
  "version": "0.0.11",
  "publisher": "local",
  "private": true,
  "engines": {
    "vscode": "^1.85.0"
  },
  "categories": [
    "Other"
  ],
  "repository": {
    "type": "git",
    "url": "https://github.com/abslabs-io/claude-todos.git"
  },
  "main": "./out/extension.js",
  "activationEvents": [
    "onStartupFinished"
  ],
  "contributes": {
    "viewsContainers": {
      "activitybar": [
        {
          "id": "claudeTodos",
          "title": "Claude Todos",
          "icon": "media/icon.svg"
        }
      ]
    },
    "views": {
      "claudeTodos": [
        {
          "id": "claudeTodos.list",
          "name": "Todos",
          "type": "tree"
        }
      ]
    },
    "viewsWelcome": [
      {
        "view": "claudeTodos.list",
        "contents": "No active Claude sessions found.\n\nSessions are shown if they're for this workspace or were touched within the active session window (configurable via `claudeTodos.activeSessionMinutes`, default 30 minutes).",
        "when": "claudeTodos.state == noSessions"
      }
    ],
    "commands": [
      {
        "command": "claudeTodos.refresh",
        "title": "Refresh Claude Todos",
        "icon": "$(refresh)"
      },
      {
        "command": "claudeTodos.expandAll",
        "title": "Expand All Claude Todos",
        "icon": "$(expand-all)"
      }
    ],
    "menus": {
      "view/title": [
        {
          "command": "claudeTodos.expandAll",
          "when": "view == claudeTodos.list",
          "group": "navigation@1"
        },
        {
          "command": "claudeTodos.refresh",
          "when": "view == claudeTodos.list",
          "group": "navigation@2"
        }
      ]
    },
    "configuration": {
      "title": "Claude Todos",
      "properties": {
        "claudeTodos.activeSessionMinutes": {
          "type": "number",
          "default": 30,
          "minimum": 1,
          "maximum": 1440,
          "description": "How recently a Claude session must have been touched (in minutes) to appear in the panel. Default 30, max 1 day."
        }
      }
    }
  },
  "scripts": {
    "build": "tsc -p .",
    "watch": "tsc -p . -w",
    "package": "vsce package",
    "vscode:prepublish": "tsc -p ."
  },
  "devDependencies": {
    "@types/node": "^24.0.0",
    "@types/vscode": "^1.85.0",
    "@vscode/vsce": "^3.9.1",
    "typescript": "^5.4.0"
  }
}
