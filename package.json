{
  "name": "coding-session-todos",
  "displayName": "Coding Session Todos",
  "description": "Live sidebar view of your Claude Code sessions — todos, state, and context usage — across all your open windows.",
  "version": "0.0.15",
  "publisher": "abslabs",
  "license": "MIT",
  "author": "Abhishek Kapadiya",
  "icon": "media/icon-128.png",
  "engines": {
    "vscode": "^1.85.0"
  },
  "categories": [
    "AI",
    "Visualization",
    "Other"
  ],
  "keywords": [
    "claude",
    "claude code",
    "sessions",
    "todos",
    "todo",
    "to-do",
    "to do",
    "todo list",
    "tasks",
    "task",
    "task list",
    "checklist",
    "ai",
    "agent"
  ],
  "repository": {
    "type": "git",
    "url": "https://github.com/abslabs-io/coding-session-todos.git"
  },
  "bugs": {
    "url": "https://github.com/abslabs-io/coding-session-todos/issues"
  },
  "homepage": "https://github.com/abslabs-io/coding-session-todos#readme",
  "main": "./out/extension.js",
  "activationEvents": [
    "onStartupFinished"
  ],
  "contributes": {
    "viewsContainers": {
      "activitybar": [
        {
          "id": "codingSessionTodos",
          "title": "Coding Session Todos",
          "icon": "media/icon.svg"
        }
      ]
    },
    "views": {
      "codingSessionTodos": [
        {
          "id": "codingSessionTodos.list",
          "name": "Todos",
          "type": "tree"
        }
      ]
    },
    "viewsWelcome": [
      {
        "view": "codingSessionTodos.list",
        "contents": "No active Claude sessions found.\n\nSessions appear here once Claude Code touches a transcript in this workspace, or within the active session window (configurable via `codingSessionTodos.activeSessionMinutes`, default 30 minutes).\n\n[Refresh](command:codingSessionTodos.refresh)\n[Open Settings](command:codingSessionTodos.openSettings)",
        "when": "codingSessionTodos.state == noSessions"
      }
    ],
    "commands": [
      {
        "command": "codingSessionTodos.refresh",
        "title": "Refresh",
        "category": "Coding Session Todos",
        "icon": "$(refresh)"
      },
      {
        "command": "codingSessionTodos.expandAll",
        "title": "Expand All",
        "category": "Coding Session Todos",
        "icon": "$(expand-all)"
      },
      {
        "command": "codingSessionTodos.collapseAll",
        "title": "Collapse All",
        "category": "Coding Session Todos",
        "icon": "$(collapse-all)"
      },
      {
        "command": "codingSessionTodos.openSettings",
        "title": "Settings",
        "category": "Coding Session Todos",
        "icon": "$(gear)"
      }
    ],
    "menus": {
      "view/title": [
        {
          "command": "codingSessionTodos.refresh",
          "when": "view == codingSessionTodos.list",
          "group": "navigation@1"
        },
        {
          "command": "codingSessionTodos.expandAll",
          "when": "view == codingSessionTodos.list",
          "group": "navigation@2"
        },
        {
          "command": "codingSessionTodos.collapseAll",
          "when": "view == codingSessionTodos.list",
          "group": "navigation@3"
        },
        {
          "command": "codingSessionTodos.openSettings",
          "when": "view == codingSessionTodos.list",
          "group": "navigation@4"
        }
      ]
    },
    "configuration": {
      "title": "Coding Session Todos",
      "properties": {
        "codingSessionTodos.activeSessionMinutes": {
          "type": "number",
          "default": 30,
          "minimum": 5,
          "maximum": 1440,
          "description": "How recently a Claude session must have been touched (in minutes) to appear in the panel. Default 30, max 1 day."
        }
      }
    }
  },
  "scripts": {
    "build": "tsc -p .",
    "watch": "tsc -p . -w",
    "icon": "node scripts/gen-icon.js",
    "package": "vsce package",
    "vscode:prepublish": "tsc -p .",
    "typecheck": "tsc --noEmit -p tsconfig.test.json",
    "lint": "eslint .",
    "format": "prettier --write .",
    "format:check": "prettier --check .",
    "test": "vitest run",
    "test:watch": "vitest",
    "prepare": "node scripts/setup-hooks.js"
  },
  "devDependencies": {
    "@eslint/js": "^10.0.1",
    "@types/node": "^24.0.0",
    "@types/vscode": "^1.85.0",
    "@vscode/vsce": "^3.9.1",
    "eslint": "^10.5.0",
    "eslint-config-prettier": "^10.1.8",
    "prettier": "^3.8.4",
    "typescript": "^5.4.0",
    "typescript-eslint": "^8.62.0",
    "vitest": "^4.1.7"
  }
}
